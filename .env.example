# Lodestar — environment variables
# Copy this file to .env.local and fill in your values. NEVER commit .env.local.

# Google Gemini (Google Gen AI SDK: "@google/genai")
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-3.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-2
EMBED_DIM=1536

# Supabase (Session 2)
# URL and anon key are exposed to the browser, so they use the NEXT_PUBLIC_
# prefix that Next.js requires for client-side env vars.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER ONLY. Never prefix with NEXT_PUBLIC_ and never import
# it into client code. Find it in Supabase: Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Ingestion (Session 3)
# Shared secret guarding POST /api/ingest. Send it as the x-admin-ingest-token
# header. Generate one with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_INGEST_TOKEN=
